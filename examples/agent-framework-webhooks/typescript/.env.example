E2A_API_KEY=your_e2a_api_key
E2A_WEBHOOK_SECRET=whsec_your_webhook_secret
# Optional for self-hosted/local deployments; omit for https://api.e2a.dev.
# E2A_API_URL=http://localhost:8080

AGENT_FRAMEWORK=fake

# Choose the matching provider credential when AGENT_FRAMEWORK is not fake.
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_API_KEY=your_google_api_key

# Optional model overrides.
OPENAI_MODEL=gpt-5.6
ANTHROPIC_MODEL=claude-opus-4-8
LANGCHAIN_MODEL=openai:gpt-5.4
ADK_MODEL=gemini-flash-latest

# Alternatively, configure ADK for Vertex AI instead of an API key.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your_google_cloud_project
# GOOGLE_CLOUD_LOCATION=us-central1
