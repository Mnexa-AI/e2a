# e2a webhook delivery (required by the FastAPI server)
E2A_API_KEY=e2a_replace_me
E2A_WEBHOOK_SECRET=whsec_replace_me
# Optional; defaults to the hosted e2a API shown here.
E2A_API_URL=https://api.e2a.dev

# Exactly one of: fake, openai, anthropic, langchain, adk.
# fake is deterministic and requires no provider key.
AGENT_FRAMEWORK=fake

# OpenAI Agents SDK and LangChain OpenAI
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.6
LANGCHAIN_MODEL=openai:gpt-5.5

# Anthropic Messages SDK
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=claude-opus-4-8

# Google ADK / Gemini
GOOGLE_API_KEY=replace_me
ADK_MODEL=gemini-flash-latest
