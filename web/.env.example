# Web dashboard config. Copy to .env.local and adjust for your deployment.
# All vars are NEXT_PUBLIC_* so they're inlined at build time and visible to
# the browser — never put secrets here.

# Externally visible base URL of this dashboard. Used for SEO metadata
# (canonical, sitemap, robots.txt, OpenGraph) and as the curl example host
# on the landing page. Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Display name shown in titles, OG tags, and structured data.
NEXT_PUBLIC_SITE_NAME=e2a

# Optional. Shared mail domain for slug-based agent registration
# (e.g. agents.example.com). When set, the landing page mentions it in code
# examples; when empty, the page falls back to "your-domain.com" placeholders.
NEXT_PUBLIC_AGENTS_DOMAIN=

# Optional. Address shown on the in-app feedback form. Empty hides the
# fallback "or email us at …" line.
NEXT_PUBLIC_FEEDBACK_EMAIL=

# Optional. Google Search Console verification token. Only emitted into
# <head> when set, so forks don't accidentally inherit upstream's property.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
